#compdef tgr

autoload -U is-at-least

_tgr() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tgr_commands" \
"*::: :->tgr" \
&& ret=0
    case $state in
    (tgr)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tgr-command-$line[1]:"
        case $line[1] in
            (count)
_arguments "${_arguments_options[@]}" : \
'-f+[File where to search for tags]:FILE:_files' \
'--file=[File where to search for tags]:FILE:_files' \
'-i+[Override config by including files that match <PATTERN>]:INCLUDE:_default' \
'--include=[Override config by including files that match <PATTERN>]:INCLUDE:_default' \
'-e+[Override config by excluding files that match <PATTERN>]:EXCLUDE:_default' \
'--exclude=[Override config by excluding files that match <PATTERN>]:EXCLUDE:_default' \
'-h[Print help]' \
'--help[Print help]' \
'::pattern -- Pattern to search for tags:_default' \
&& ret=0
;;
(locate)
_arguments "${_arguments_options[@]}" : \
'-i+[Override config by including files that match <PATTERN>]:INCLUDE:_default' \
'--include=[Override config by including files that match <PATTERN>]:INCLUDE:_default' \
'-e+[Override config by excluding files that match <PATTERN>]:EXCLUDE:_default' \
'--exclude=[Override config by excluding files that match <PATTERN>]:EXCLUDE:_default' \
'-s[Match the pattern strictly or loosely]' \
'--strict[Match the pattern strictly or loosely]' \
'-h[Print help]' \
'--help[Print help]' \
':pattern -- Pattern to search for tags:_default' \
&& ret=0
;;
(refile)
_arguments "${_arguments_options[@]}" : \
'-i+[Override config by including files that match <PATTERN>]:INCLUDE:_default' \
'--include=[Override config by including files that match <PATTERN>]:INCLUDE:_default' \
'-e+[Override config by excluding files that match <PATTERN>]:EXCLUDE:_default' \
'--exclude=[Override config by excluding files that match <PATTERN>]:EXCLUDE:_default' \
'-n[Print the contents to stdout instead of pager]' \
'--no-pager[Print the contents to stdout instead of pager]' \
'-s[Match the pattern strictly or loosely]' \
'--strict[Match the pattern strictly or loosely]' \
'-h[Print help]' \
'--help[Print help]' \
':pattern -- Pattern to find Org trees to refile:_default' \
'::output_file -- Name of the output file. If not given, ouptut is paged or printed to the standard output:_default' \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
'-f+[File where to search for tags]:FILE:_files' \
'--file=[File where to search for tags]:FILE:_files' \
'-i+[Override config by including files that match <PATTERN>]:INCLUDE:_default' \
'--include=[Override config by including files that match <PATTERN>]:INCLUDE:_default' \
'-e+[Override config by excluding files that match <PATTERN>]:EXCLUDE:_default' \
'--exclude=[Override config by excluding files that match <PATTERN>]:EXCLUDE:_default' \
'-p[Force the output to a pager]' \
'--pager[Force the output to a pager]' \
'-h[Print help]' \
'--help[Print help]' \
':pattern -- Pattern used to search for tags:_default' \
&& ret=0
;;
(sed)
_arguments "${_arguments_options[@]}" : \
'-v[Print additional information about substitutions]' \
'--verbose[Print additional information about substitutions]' \
'-h[Print help]' \
'--help[Print help]' \
':tag -- The tag to be substituded. Note that this command will perform a substitution only on an exact match:_default' \
':replacement -- The replacement:_default' \
&& ret=0
;;
(tags)
_arguments "${_arguments_options[@]}" : \
'-f+[Optional file to search instead of searching in the whole Org directory]:FILE:_files' \
'--file=[Optional file to search instead of searching in the whole Org directory]:FILE:_files' \
'-p[Force the output to a pager]' \
'--pager[Force the output to a pager]' \
'-P[Print all the tags into a .txt file]' \
'--print[Print all the tags into a .txt file]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tgr__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tgr-help-command-$line[1]:"
        case $line[1] in
            (count)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(locate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(refile)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(sed)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tags)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_tgr_commands] )) ||
_tgr_commands() {
    local commands; commands=(
'count:Print the number of tags that match <pattern>' \
'locate:Locate the files that contain a tag matching <PATTERN>' \
'refile:Refile org trees that have tags that match a pattern' \
'search:Search tags in Org directory or file' \
'sed:A wrapper around the \`sed\` cli utility to safely manipulate tags' \
'tags:Print tags to stdout or to pager' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tgr commands' commands "$@"
}
(( $+functions[_tgr__count_commands] )) ||
_tgr__count_commands() {
    local commands; commands=()
    _describe -t commands 'tgr count commands' commands "$@"
}
(( $+functions[_tgr__help_commands] )) ||
_tgr__help_commands() {
    local commands; commands=(
'count:Print the number of tags that match <pattern>' \
'locate:Locate the files that contain a tag matching <PATTERN>' \
'refile:Refile org trees that have tags that match a pattern' \
'search:Search tags in Org directory or file' \
'sed:A wrapper around the \`sed\` cli utility to safely manipulate tags' \
'tags:Print tags to stdout or to pager' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tgr help commands' commands "$@"
}
(( $+functions[_tgr__help__count_commands] )) ||
_tgr__help__count_commands() {
    local commands; commands=()
    _describe -t commands 'tgr help count commands' commands "$@"
}
(( $+functions[_tgr__help__help_commands] )) ||
_tgr__help__help_commands() {
    local commands; commands=()
